      "headline": ["프롬프트 말고", "세팅부터"],
      "support_copy": "목표, 타깃, 톤, 금지사항을 먼저 넣어야 결과가 흔들리지 않는다.",
      "image_role": "asset_mockup",
      "visual_direction": "cream top, dark bottom, Claude prompt UI mockups, two bottom white cards top-aligned",
      "elements": [
        {
          "id": "brand",
          "type": "text",
          "job": "brand_identification",
          "content": "NODEV BUILDER",
          "priority": 2,
          "must_be_readable": true,
          "notes": "top-center fixed"
