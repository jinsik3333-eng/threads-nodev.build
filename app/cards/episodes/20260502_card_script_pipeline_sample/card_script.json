    {
      "slide_id": "05",
      "role": "storyboard_preview",
      "template_id": "T06_STORYBOARD_PREVIEW",
      "message": "초안은 바로 업로드되는 것이 아니라 6장 흐름으로 분해되어야 한다.",
      "headline": ["초안이 콘텐츠가", "되는 순서"],
      "support_copy": "Hook → Bridge → Prompt → Assets → Flow → CTA",
      "image_role": "asset_mockup",
      "visual_direction": "storyboard document mockup, 6 frame thumbnails, no tool network",
      "elements": [
        {
          "id": "brand",
          "type": "text",
          "job": "brand_identification",
          "content": "NODEV BUILDER",
          "priority": 2,
          "must_be_readable": true,
          "notes": "top-center fixed"
        },
        {
          "id": "storyboard_doc",
          "type": "mockup",
          "job": "story_progression",
          "content": "01 Hook / 02 Bridge / 03 Prompt / 04 Assets / 05 Flow / 06 CTA",
