          "id": "definition",
          "type": "text",
          "job": "instruction",
          "content": "목표, 타깃, 톤, 금지사항을 먼저 넣는다.",
          "priority": 1,
          "must_be_readable": true,
          "notes": "short support copy"
        },
        {
          "id": "prompt_mockup_01",
          "type": "mockup",
          "job": "proof_result",
          "content": "Brand Context",
          "priority": 1,
          "must_be_readable": true,
          "notes": "bottom white card top-aligned with card 02"
        },
        {
          "id": "prompt_mockup_02",
          "type": "mockup",
          "job": "proof_result",
          "content": "Output Format",
          "priority": 1,
          "must_be_readable": true,
          "notes": "bottom white card top-aligned with card 01"
        }
      ],
      "qa_rules": ["bottom_mockups_top_aligned", "ui_text_min_22px"]
    },
    {
      "slide_id": "04",
      "role": "generated_assets",
      "template_id": "T07_ASSET_LIBRARY",
      "message": "Claude 결과물을 캡션/후킹/이미지/캘린더 에셋 묶음으로 보여준다.",
      "headline": ["결과물은", "에셋으로 묶는다"],
      "support_copy": "hooks, captions, visuals, calendar가 한 세트로 나와야 바로 쓸 수 있다.",
      "image_role": "asset_mockup",
      "visual_direction": "bright asset library, folders plus thumbnail grid, premium cream and sky-blue tone",
      "elements": [
        {
          "id": "brand",
          "type": "text",
          "job": "brand_identification",
          "content": "NODEV BUILDER",
          "priority": 2,
          "must_be_readable": true,
          "notes": "top-center fixed"
        },
        {
          "id": "asset_folder",
