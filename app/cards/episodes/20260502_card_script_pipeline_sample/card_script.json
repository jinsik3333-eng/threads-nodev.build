          "must_be_readable": true,
          "notes": "this replaces ambiguous tool network"
        }
      ],
      "qa_rules": ["no_tool_network", "sequence_reads_in_order", "frame_labels_min_22px"]
    },
    {
      "slide_id": "06",
      "role": "final_cta",
      "template_id": "T08_FINAL_COMMENT_CTA",
      "message": "댓글 키워드로 30일치 콘텐츠 프롬프트 템플릿을 받을 수 있게 한다.",
      "headline": ["댓글에", "30일치"],
      "support_copy": "콘텐츠 캘린더 프롬프트 템플릿을 DM으로 보내드릴게요.",
      "image_role": "none",
      "visual_direction": "dark premium CTA, no meaningless bright box, clear comment keyword and follow instruction",
      "elements": [
        {
          "id": "brand",
          "type": "text",
          "job": "brand_identification",
          "content": "NODEV BUILDER",
          "priority": 2,
          "must_be_readable": true,
          "notes": "top-center fixed"
        },
        {
          "id": "keyword",
          "type": "text",
          "job": "cta_action",
          "content": "댓글에 30일치",
          "priority": 1,
          "must_be_readable": true,
          "notes": "keyword must be visually obvious"
        },
        {
          "id": "dm_resource",
          "type": "text",
          "job": "content_preview",
          "content": "콘텐츠 캘린더 프롬프트 템플릿",
          "priority": 1,
          "must_be_readable": true,
          "notes": "resource is explicit; no vague bright box"
        },
        {
          "id": "follow",
          "type": "text",
          "job": "cta_action",
          "content": "AI 워크플로우 더 보려면 팔로우",
