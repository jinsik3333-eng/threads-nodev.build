{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Nodev Builder Card Script",
  "type": "object",
  "required": ["version", "project", "format", "style_profile", "brand", "font_policy", "global_qa_rules", "slides"],
  "properties": {
    "version": { "type": "string" },
    "project": { "type": "string" },
    "episode_slug": { "type": "string" },
    "format": {
      "type": "object",
      "required": ["width", "height", "platform"],
      "properties": {
        "width": { "const": 1080 },
        "height": { "const": 1350 },
        "platform": { "const": "instagram-carousel" }
      }
    },
    "style_profile": { "type": "string" },
    "brand": {
      "type": "object",
      "required": ["account_name", "account_position", "required_on_all_slides"],
      "properties": {
        "account_name": { "type": "string" },
        "account_position": { "const": "top-center" },
        "required_on_all_slides": { "const": true }
      }
    },
    "font_policy": {
      "type": "object",
      "required": ["headline", "body", "ui", "min_readable_px"],
      "properties": {
        "headline": { "type": "string" },
        "body": { "type": "string" },
        "ui": { "type": "string" },
        "min_readable_px": { "type": "number", "minimum": 22 }
      }
    },
    "global_qa_rules": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_id", "role", "template_id", "message", "headline", "support_copy", "image_role", "visual_direction", "elements", "qa_rules"],
        "properties": {
          "slide_id": { "type": "string", "pattern": "^[0-9]{2}$" },
          "role": { "type": "string" },
          "template_id": { "type": "string", "pattern": "^T[0-9]{2}_[A-Z0-9_]+$" },
          "message": { "type": "string", "minLength": 5 },
          "headline": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "maxItems": 4
          },
          "support_copy": { "type": "string" },
          "image_role": {
            "type": "string",
            "enum": ["none", "desire_hook", "proof", "transition", "comparison", "detail_check", "asset_mockup", "mood_bridge"]
          },
          "visual_direction": { "type": "string" },
          "elements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "type", "job", "content", "priority", "must_be_readable", "notes"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "job": {
                  "type": "string",
                  "enum": ["brand_identification", "hook_message", "story_progression", "proof_result", "content_preview", "instruction", "comparison_basis", "cta_action", "visual_rhythm_break", "decoration_only"]
                },
                "content": { "type": "string" },
                "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
                "must_be_readable": { "type": "boolean" },
                "notes": { "type": "string" }
              }
            }
          },
          "qa_rules": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
