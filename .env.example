# Meta Developer App 인증 정보
# 1. https://developers.facebook.com 에서 앱 생성
# 2. Instagram Basic Display / Instagram Graph API 제품 추가
# 3. Instagram 계정을 Creator/Business Account로 전환
# 4. 토큰 생성 후 아래에 붙여넣기

# Threads API (graph.threads.net)
THREADS_ACCESS_TOKEN=your_long_lived_token_here
THREADS_USER_ID=your_numeric_user_id_here

# Instagram Graph API (graph.instagram.com) — 공식 API
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Claude API (콘텐츠 생성)
ANTHROPIC_API_KEY=your_anthropic_key_here